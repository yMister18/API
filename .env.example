# --- Servidor ---
PORT=3333
NODE_ENV=development

# URL do frontend (para CORS e redirects pós-login)
FRONTEND_URL=http://localhost:5173

# Origens adicionais para CORS, separadas por vírgula (opcional)
CORS_ORIGIN=http://localhost:5173

# --- Base de dados ---
DATABASE_URL="postgresql://warpion:warpion@localhost:5432/warpion?schema=public"

# --- Sessão / JWT ---
# Gera um valor aleatório forte, ex: `openssl rand -hex 32`
JWT_SECRET=change-me-please-super-secret
COOKIE_SECRET=change-me-too-super-secret
SESSION_COOKIE_NAME=warpion_session

# --- Discord OAuth2 ---
# Cria uma app em https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:3333/auth/discord/callback

# --- Integrações internas (plugin do servidor Minecraft) ---
# Chave partilhada usada nos endpoints /internal/* (header: x-internal-api-key)
INTERNAL_API_KEY=change-me-internal-key
